{# @var ea \EasyCorp\Bundle\EasyAdminBundle\Context\AdminContext #}
{% extends '@EasyAdmin/layout.html.twig' %}
{% form_theme form '@EasyAdmin/crud/form_theme.html.twig' %}

{% block page_title %}
    Edit Config -
{% endblock page_title %}

{% macro scope_links(scopes, currentScope, configPath, spaces) %}
    {% for scopeKey, scopeData in scopes %}
        <option
                {% if currentScope == scopeKey %} selected {% endif %}
                value="{{ ea_url().setRoute('comfy_configs', {"scope": scopeKey, "config": configPath}) }}"
        >
            {{ spaces|raw }}{{ scopeData.name }}
        </option>

        {% if scopeData.sub_scopes %}
            {{ _self.scope_links(scopeData.sub_scopes, currentScope, configPath, spaces ~ "&nbsp;&nbsp;&nbsp;&nbsp;") }}
        {% endif %}
    {% endfor %}
{% endmacro %}

{% macro config_tree(configs, parent, currentScope, currentConfigPath) %}
    {% for configKey, config in configs %}
        {% if config is iterable %}
            {% set path = parent ~ "." ~ configKey %}
            {% set normalizedPath = path|replace({'.': '/'})|trim('/') %}
            <li>
                {% set subElements = _self.config_tree(config, path, currentScope, currentConfigPath) %}

                {% if subElements|replace({' ': ''}) == "" %}
                    <a
                            class="d-block py-1 px-2 rounded text-decoration-none{{ normalizedPath == currentConfigPath ? ' fw-semibold text-primary bg-primary-subtle' : ' link-body-emphasis' }}"
                            href="{{ ea_url().setRoute('comfy_configs', {"scope": currentScope, "config": path}) }}"
                    >
                        {{ ("comfy" ~ path ~ ".name")|trans }}
                    </a>
                {% else %}
                    <span class="d-block py-1 px-2 fw-semibold">{{ ("comfy" ~ path ~ ".name")|trans }}</span>
                    <ul class="list-unstyled ps-3">
                        {{ subElements }}
                    </ul>
                {% endif %}
            </li>
        {% endif %}
    {% endfor %}
{% endmacro %}

{% block content %}

    {{ form_start(form) }}

    <nav class="navbar navbar-expand-lg navbar-light bg-light">
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarSupportedContent">
            <ul class="navbar-nav me-auto">
                <li class="nav-item dropdown">
                    <select class="form-select" onchange="location = this.options[this.selectedIndex].value;">
                        {{ _self.scope_links(scopes.sub_scopes, scope, config_path, '') }}
                    </select>
                </li>
            </ul>
            <div class="my-2 my-lg-0">
                {{ form_row(form.save) }}
            </div>
        </div>
    </nav>

    <div class="mt-2">
        <div class="row">
            <div class="col-3">
                <div class="card">
                    <div class="card-body">
                        <ul class="list-unstyled mb-0">
                            {{ _self.config_tree(config_tree, "", scope, config_path) }}

                        </ul>
                    </div>
                </div>
            </div>
            <div class="col-9">
                <div class="card">
                    <div class="card-body">
                        {{ form_errors(form) }}

                        {% for config_key in config_keys %}
                            <div class="row config-entry align-items-center py-2 border-bottom">
                                <div class="col-8 config-entry__input">
                                    {{ form_row(attribute(form, config_key).value) }}
                                </div>
                                <div class="col-4 config-entry__use-parent">
                                    <div class="form-check form-switch">
                                        {{ form_widget(attribute(form, config_key).use_parent, {attr: {class: 'form-check-input'}}) }}
                                        {{ form_label(attribute(form, config_key).use_parent, null, {label_attr: {class: 'form-check-label'}}) }}
                                    </div>
                                    {{ form_errors(attribute(form, config_key).use_parent) }}
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
    </div>

    {{ form_end(form) }}


    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.config-entry').forEach(function (configEntry) {
                const mainInputs = configEntry.querySelectorAll(
                    '.config-entry__input input, .config-entry__input textarea, .config-entry__input select'
                );
                const useParentCheckbox = configEntry.querySelector('.config-entry__use-parent input');

                const handleUseParentChange = function () {
                    mainInputs.forEach(function (input) {
                        input.required = !useParentCheckbox.checked;
                        input.disabled = useParentCheckbox.checked;
                    });
                };

                handleUseParentChange();
                useParentCheckbox.addEventListener('change', handleUseParentChange);
            });
        });
    </script>
{% endblock content %}

